{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emphant Studio",
  "version": "0.1.0",
  "identifier": "com.emphant.studio",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Emphant Studio",
        "width": 1480,
        "height": 940,
        "minWidth": 1200,
        "minHeight": 760,
        "backgroundColor": "#0f1115",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.png"
    ]
  }
}
